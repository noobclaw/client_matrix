# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.idea/
*.swp
*.swo
chrome-extension.zip

# Browser extension is no longer bundled — users install the NoobClaw
# Browser Assistant from the Chrome / Firefox / Edge stores. Source for
# the extension lives in the private noobclaw/chrome-extension repo.
# The two paths below are kept ignored so that an accidental local clone
# of the extension repo or a stale build artifact doesn't sneak back in.
chrome-extension/
src-tauri/resources/chrome-extension/

# TS incremental build cache
tsconfig.node.tsbuildinfo
